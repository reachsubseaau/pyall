{
  // qc.all MCP server configuration for VS Code.
  // - "qcall" (stdio): VS Code launches the server for you using the project's venv.
  // - "qcall-http": connect to a server you started yourself with
  //       .venv\Scripts\python.exe qcall_mcp.py --http --host 0.0.0.0 --port 8000 --root <data-folder>
  //   Start that process first, then start this server entry in VS Code.
  "servers": {
    "qcall": {
      "type": "stdio",
      "command": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": ["${workspaceFolder}/qcall_mcp.py"]
    },
    "qcall-http": {
      "type": "http",
      "url": "http://localhost:8000/mcp"
    }
  }
}
